---
layout: base.njk
---
{% for comp in competitions %}{% if comp.title == tag %}{% set competitionTheme = comp.theme %}{% endif %}{% endfor %}
{% set team = teams[tag] %}
<h1>{{ tag }} Games</h1>


<p class="subscribe">
    <a href="{{ ('/' + (tag | slugify) + '/') | url | absoluteUrl(config.baseUrl) | webcal }}">
        <span role="img">🗓</span>
        <span>Add {{ tag }} games to your calendar</span>
        <small>in iOS, MacOS and Office</small>
    </a>
</p>

{% if team %}
<section class="team-info" {% if team.colours %}style="--team-primary:{{ team.colours.primary }};--team-secondary:{{ team.colours.secondary }}"{% endif %}>
    <div class="team-colours" aria-hidden="true">
        {% if team.colours %}
        <span class="colour-swatch" style="background:{{ team.colours.primary }}"></span>
        <span class="colour-swatch" style="background:{{ team.colours.secondary }}"></span>
        {% endif %}
    </div>
    <p class="team-description">{{ team.description }}</p>
    <p class="team-meta">
        <span>Federation: <strong>{{ team.federation }}</strong></span>
        {% if team.fifaCode %}<span>FIFA code: <strong>{{ team.fifaCode }}</strong></span>{% endif %}
    </p>
</section>
{% endif %}

<nav class="tabs" aria-label="Timeline view">
    <a class="tab" id="tab-upcoming" href="#">Upcoming</a>
    <a class="tab" id="tab-previous" href="#">Previous</a>
</nav>

<table id="game-list">
    <thead>
        <tr>
            <th>Day</th>
            <th>Time</th>
            <th>Summary</th>
        </tr>
    </thead>
    <tbody>
        {% set lastDate = '' %}
        {% for game in collections[tag] %}
            {% set showDate = false %}
            {% if game.data.date | date('ccc dS LLLL') != lastDate %}
                {% set lastDate = game.data.date | date('ccc dS LLLL') %}
                {% set showDate = true %}
            {% endif %}
            <tr class="vevent h-event" data-location="{{ game.data.locationName }}" data-tags="{{ game.data.tags | join(',') }}">
                <td class="datetime">
                    <span class="day">{% if showDate %}{{ game.data.date | date('ccc dS LLLL') }}{% endif %}</span>
                </td>
                <td class="time">
                    <span class="starttime">{{ game.data.date | date('H:mm') }}</span>
                    <time class="dt-start" datetime="{{ game.data.date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}">{{ game.data.date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}</time>
                    <time class="dt-end" datetime="{{ game.data.endDate | date("yyyy-LL-dd'T'H:mm:ssZZZ") }}">{{ game.data.endDate | date("yyyy-LL-dd'T'H:mm:ssZZZ") }}</time>
                </td>
                <td class="summary">
                    <a class="p-name u-url" href="{{ game.page.url | url }}">{{ game.data.title }}</a>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
<p class="timezone-info" style="display:none;"></p>
<script>
(function () {
  var now      = new Date()
  var tbody    = document.querySelector('#game-list tbody')
  var tabUp    = document.getElementById('tab-upcoming')
  var tabPrev  = document.getElementById('tab-previous')
  var rows     = document.querySelectorAll('tr.vevent')
  var nextRow  = null
  var reduced  = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // ── 1. Classify rows (preserve existing past/next logic) ─────────────────
  rows.forEach(function (row) {
    var dtEnd   = row.querySelector('time.dt-end')
    var dtStart = row.querySelector('time.dt-start')
    var endText = dtEnd && dtEnd.textContent.trim()
    var endTime = endText ? new Date(endText) : null

    if (!endTime || isNaN(endTime.getTime())) {
      var startText = dtStart && dtStart.textContent.trim()
      endTime = startText ? new Date(startText) : null
    }

    if (!endTime || isNaN(endTime.getTime())) return

    if (endTime < now) {
      row.classList.add('past')
    } else if (!nextRow) {
      row.classList.add('next')
      nextRow = row
    }
  })

  if (!tbody || !tabUp || !tabPrev) return

  // ── 2. NOW divider ────────────────────────────────────────────────────────
  var nowRow = document.createElement('tr')
  nowRow.className = 'now-row'
  nowRow.id        = 'now'
  nowRow.innerHTML =
    '<td colspan="3"><div class="now-divider">' +
    '<span class="now-badge"><span class="pulse-dot"></span>Next</span>' +
    '</div></td>'

  // ── 3a. Upcoming games exist ──────────────────────────────────────────────
  if (nextRow) {
    var link     = nextRow.querySelector('.summary a')
    var dtStart  = nextRow.querySelector('time.dt-start')
    var gameDate = new Date(dtStart ? dtStart.textContent.trim() : '')
    var title    = link ? link.textContent.trim() : ''
    var href     = link ? link.getAttribute('href') : '#'

    var vIdx = title.indexOf(' v ')
    var home = vIdx > -1 ? title.slice(0, vIdx).trim() : title
    var away = vIdx > -1 ? title.slice(vIdx + 3).trim() : ''

    function ordinal (n) {
      var s = ['th', 'st', 'nd', 'rd']
      var v = n % 100
      return n + (s[(v - 20) % 10] || s[v] || s[0])
    }

    var dateStr = ''
    if (!isNaN(gameDate.getTime())) {
      var weekdayStr = gameDate.toLocaleDateString('en-GB', { weekday: 'short' })
      var monthStr = gameDate.toLocaleDateString('en-GB', { month: 'long' })
      dateStr = weekdayStr + ' ' + ordinal(gameDate.getDate()) + ' ' + monthStr
    }
    var timeStr = isNaN(gameDate.getTime()) ? '' : gameDate.toLocaleTimeString('en-GB', {
      hour: '2-digit', minute: '2-digit'
    })

    var heroRow = document.createElement('tr')
    heroRow.className = 'hero-row'
    heroRow.id        = 'upcoming'
    heroRow.innerHTML =
      '<td colspan="3">' +
        '<a class="next-card" href="' + href + '">' +
          '<div class="card-teams">' +
            '<span class="card-home">' + home + '</span>' +
            (away ? '<span class="card-sep">— v —</span><span class="card-away">' + away + '</span>' : '') +
          '</div>' +
          '<div class="card-meta">' +
            (dateStr ? '<span>' + dateStr + '</span>' : '') +
            (timeStr ? '<span>' + timeStr + '</span>' : '') +
          '</div>' +
        '</a>' +
      '</td>'

    tbody.insertBefore(nowRow, nextRow)
    tbody.insertBefore(heroRow, nextRow)
    nextRow.setAttribute('hidden', '')

    tabUp.classList.add('tab-active')
    tabPrev.classList.add('tab-inactive')

    tabUp.addEventListener('click', function (e) {
      e.preventDefault()
      var top = heroRow.getBoundingClientRect().top + window.scrollY - 100
      window.scrollTo({ top: Math.max(0, top), behavior: reduced ? 'auto' : 'smooth' })
    })

    tabPrev.addEventListener('click', function (e) {
      e.preventDefault()
      var firstPast = tbody.querySelector('tr.past')
      var top = firstPast ? firstPast.getBoundingClientRect().top + window.scrollY - 100 : 0
      window.scrollTo({ top: Math.max(0, top), behavior: reduced ? 'auto' : 'smooth' })
    })

    function scrollToNow() {
      var top = nowRow.getBoundingClientRect().top + window.scrollY - 120
      window.scrollTo({ top: Math.max(0, top), behavior: reduced ? 'auto' : 'smooth' })
    }
    if (document.readyState === 'complete') { scrollToNow() }
    else { window.addEventListener('load', scrollToNow) }

  // ── 3b. All games in the past ─────────────────────────────────────────────
  } else {
    tbody.appendChild(nowRow)
    tabUp.classList.add('tab-disabled')
    tabUp.setAttribute('aria-disabled', 'true')
    tabUp.addEventListener('click', function (e) { e.preventDefault() })
    tabPrev.classList.add('tab-active')
  }
}())
</script>
{% if config.GOOGLE_ADSENSE_PUBLISHER_ID and config.GOOGLE_ADSENSE_SLOT_COMPETITION and collections[tag].length >= 8 %}
<div class="ad-container">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="{{ config.GOOGLE_ADSENSE_PUBLISHER_ID }}"
         data-ad-slot="{{ config.GOOGLE_ADSENSE_SLOT_COMPETITION }}"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>
{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ (tag + " Games") | dump | safe }},
  "description": {{ pageDescription | dump | safe }},
  "url": {{ (('/' + (tag | slugify) + '/') | absoluteUrl(config.baseUrl)) | dump | safe }},
  "itemListElement": [
    {% for game in collections[tag] %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": "SportsEvent",
        "name": {{ game.data.title | dump | safe }},
        "startDate": "{{ game.data.date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}",
        "endDate": "{{ game.data.endDate | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}",
        "sport": "Football",
        "location": { "@type": "Place", "name": {{ game.data.locationName | dump | safe }} },
        "url": {{ (game.page.url | absoluteUrl(config.baseUrl)) | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{% set feedComp = null %}
{% for comp in competitions %}{% if tag and (comp.title == tag or comp.shortTitle == tag) %}{% set feedComp = comp %}{% endif %}{% endfor %}
{% if feedComp %}
<p class="feed-links">Also available as <a href="{{ ('/' + feedComp.theme + '.json') | url }}" type="application/feed+json" title="{{ feedComp.title }} JSON feed">JSON</a> and <a href="{{ ('/' + feedComp.theme + '.rss') | url }}" type="application/rss+xml" title="{{ feedComp.title }} RSS feed">RSS</a> feeds.</p>
{% endif %}
<h2>Want more?</h2>
<p>
    <a href="{{ '/' | url }}">All games</a>
</p>
