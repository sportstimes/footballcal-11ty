---
layout: base.njk
---
<div class="event-post h-event">
    {% set competitionName = null %}
    {% for comp in competitions %}{% if comp.title in tags or (comp.shortTitle and comp.shortTitle in tags) %}{% set competitionName = comp.title %}{% endif %}{% endfor %}
    {% if competitionName %}<div class="competition">{{ competitionName }}</div>{% endif %}

    <h1 class="p-name">{{ title }}</h1>

    {%- set t1Name = title.split(' v ')[0] %}
    {%- set t2Name = title.split(' v ')[1] %}
    {%- set t1 = teams[t1Name] %}
    {%- set t2 = teams[t2Name] %}
    {%- if t1 or t2 %}
    <div class="fixture-shirt">
      <svg class="team-shirt" viewBox="-10 -2 140 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <clipPath id="shirt-clip">
            <path d="M40,4 Q60,17 80,4 L118,4 L128,35 L100,41 L100,92 L20,92 L20,41 L-8,35 L2,4 Z"/>
          </clipPath>
        </defs>
        <polygon points="-10,-2 75,-2 35,98 -10,98" clip-path="url(#shirt-clip)" fill="{{ t1.colours.primary if t1 else '#aaa' }}"/>
        <polygon points="75,-2 130,-2 130,98 35,98" clip-path="url(#shirt-clip)" fill="{{ t2.colours.primary if t2 else '#888' }}"/>
        <line x1="75" y1="-2" x2="35" y2="98" stroke="rgba(255,255,255,0.55)" stroke-width="2" clip-path="url(#shirt-clip)"/>
        <path d="M40,4 Q60,17 80,4 L118,4 L128,35 L100,41 L100,92 L20,92 L20,41 L-8,35 L2,4 Z" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
      </svg>
      <div class="fixture-codes">
        <span class="fifa-code">{{ t1.fifaCode if t1 else t1Name }}</span>
        <span class="code-sep">×</span>
        <span class="fifa-code">{{ t2.fifaCode if t2 else t2Name }}</span>
      </div>
    </div>
    {%- endif %}

    <div class="datetime">
        <p class="date">{{ date | date('ccc dS LLLL') }}</p>
        <p class="time">
            <span class="starttime">{{ date | date('h:mma') }}</span>
            <span class="endtime">–{{ endDate | date('h:mma') }}</span>
        </p>
        <time class="dt-start" datetime="{{ date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}">{{ date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}</time>
        <time class="dt-end" datetime="{{ endDate | date("yyyy-LL-dd'T'H:mm:ssZZZ") }}">{{ endDate | date("yyyy-LL-dd'T'H:mm:ssZZZ") }}</time>
        <p class="timezone-info" style="display:none;"></p>
    </div>

    <p class="subscribe">
        <a href="{{ path | url | absoluteUrl(config.baseUrl) | webcal }}">
            <span role="img">🗓</span>
            <span>Add this game to your calendar</span>
            <small>in iOS, MacOS and Office</small>
        </a>
    </p>

    <table id="EventDetails">
        <tr>
            <th>Venue</th>
            <th>TV</th>
        </tr>
        <tr>
            <td class="p-location">{{ locationName }}</td>
            <td class="tv-channels">
                {% for on in tv %}
                    <span>{{ on }}</span>
                {% endfor %}
            </td>
        </tr>
    </table>

    <div class="blog-post-content p-summary">
        {{ content | safe }}
    </div>
</div>

{%- if lastMeeting %}
<section class="last-meeting">
  <h2>Last time these sides met</h2>
  <p class="last-meeting-result">
    <strong>{{ lastMeeting.score }}</strong>
    {%- if lastMeeting.winner == 'Draw' %} — a draw{% else %} — {{ lastMeeting.winner }} won{% endif %}
  </p>
  <dl class="last-meeting-meta">
    <div>
      <dt>Date</dt>
      <dd>{{ lastMeeting.date | date('d LLLL yyyy') }}</dd>
    </div>
    <div>
      <dt>Days ago</dt>
      <dd>{{ lastMeeting.date | daysAgo | commaNumber }}</dd>
    </div>
    <div>
      <dt>Competition</dt>
      <dd>{{ lastMeeting.competition }}</dd>
    </div>
    <div>
      <dt>Venue</dt>
      <dd>{{ lastMeeting.venue }}</dd>
    </div>
  </dl>
</section>
{%- elif firstMeeting %}
<section class="last-meeting first-meeting">
  <h2>First ever meeting</h2>
  <p>This is the first time these two nations have met in international football.</p>
</section>
{%- endif %}

{% set venue = venues[locationName] %}
{% if venue %}
<section class="venue-info">
    <h2>Venue: {{ venue.stadiumName }}</h2>
    <dl class="venue-details">
        <div>
            <dt>Stadium</dt>
            <dd>{{ venue.stadiumName }}</dd>
        </div>
        <div>
            <dt>City</dt>
            <dd>{{ venue.city }}, {{ venue.country }}</dd>
        </div>
        <div>
            <dt>Capacity</dt>
            <dd>{{ venue.capacity | commaNumber }}</dd>
        </div>
    </dl>
    <p class="venue-description">{{ venue.description }}</p>
    <div class="venue-map">
        <iframe
            title="Map of {{ venue.stadiumName }}"
            loading="lazy"
            src="https://www.openstreetmap.org/export/embed.html?bbox={{ venue.lng - 0.015 }}%2C{{ venue.lat - 0.009 }}%2C{{ venue.lng + 0.015 }}%2C{{ venue.lat + 0.009 }}&amp;layer=mapnik&amp;marker={{ venue.lat }}%2C{{ venue.lng }}"
            width="100%"
            height="300"
            style="border:1px solid #ccc; border-radius: 4px;"
            referrerpolicy="no-referrer">
        </iframe>
        <p class="map-link"><a href="https://www.openstreetmap.org/?mlat={{ venue.lat }}&amp;mlon={{ venue.lng }}#map=15/{{ venue.lat }}/{{ venue.lng }}" target="_blank" rel="noopener">View larger map</a></p>
    </div>
</section>
{% endif %}

<h2>Want more?</h2>
<ul class="inline">
    {% for tag in tags | validTags %}
        <li>
            <a href="{{ ('/' + (tag | slugify) + '/') | url }}" rel="tag">{{ tag }} games</a>
        </li>
    {% endfor %}
    <li>
        <a href="{{ '/' | url }}" class="all">All games</a>
    </li>
</ul>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "name": {{ title | dump | safe }},
  "description": {{ pageDescription | dump | safe }},
  "url": {{ (path | absoluteUrl(config.baseUrl)) | dump | safe }},
  "startDate": "{{ date | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}",
  "endDate": "{{ endDate | date("yyyy-LL-dd'T'HH:mm:ssZZZ") }}",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "sport": "Football",
  "location": {
    "@type": "Place",
    "name": {% if venue %}{{ venue.stadiumName | dump | safe }}{% else %}{{ locationName | dump | safe }}{% endif %}{% if venue %},
    "address": { "@type": "PostalAddress", "addressLocality": {{ venue.city | dump | safe }}, "addressCountry": {{ venue.country | dump | safe }} },
    "geo": { "@type": "GeoCoordinates", "latitude": {{ venue.lat }}, "longitude": {{ venue.lng }} }{% endif %}
  }{% if competitors and competitors.length == 2 %},
  "competitor": [
    { "@type": "SportsTeam", "name": {{ competitors[0] | dump | safe }} },
    { "@type": "SportsTeam", "name": {{ competitors[1] | dump | safe }} }
  ]{% endif %}{% if tv and tv.length > 0 %},
  "potentialAction": {
    "@type": "WatchAction",
    "expectsAcceptanceOf": {
      "@type": "Offer",
      "availableChannel": [
        {% for channel in tv %}{ "@type": "BroadcastChannel", "broadcastChannelId": {{ channel | dump | safe }} }{% if not loop.last %},{% endif %}{% endfor %}
      ]
    }
  }{% endif %}
}
</script>

{% if config.GOOGLE_ADSENSE_PUBLISHER_ID and config.GOOGLE_ADSENSE_SLOT_GAME %}
<div class="ad-container">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="{{ config.GOOGLE_ADSENSE_PUBLISHER_ID }}"
         data-ad-slot="{{ config.GOOGLE_ADSENSE_SLOT_GAME }}"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>
{% endif %}
